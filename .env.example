# Core Environment Configurations
ENV=development
DEBUG=true
X_CORRELATION_ID_HEADER=x-correlation-id

# Networking & Service Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Database Configurations
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=ai_sales_agent_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/ai_sales_agent_dev

# Cache Configurations
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# AI Provider Configurations (Placeholder for Sprint 4)
OPENAI_API_KEY=your-openai-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Telephony Gateway Configurations (Placeholder for Sprint 3)
TWILIO_ACCOUNT_SID=your-twilio-sid-here
TWILIO_AUTH_TOKEN=your-twilio-token-here
